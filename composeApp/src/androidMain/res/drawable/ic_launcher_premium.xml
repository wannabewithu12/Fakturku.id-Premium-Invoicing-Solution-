<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Squircle (Apple-style) Background -->
    <path
        android:pathData="M54,0 C90,0 108,18 108,54 C108,90 90,108 54,108 C18,108 0,90 0,54 C0,18 18,0 54,0 Z"
        android:fillType="evenOdd">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108"
                android:type="linear">
                <item android:offset="0" android:color="#FF0F172A" /> <!-- Navy -->
                <item android:offset="1" android:color="#00A3FF" /> <!-- Cyan (Bright) -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle Frost Overlay (Top Left highlight) -->
    <path
        android:pathData="M15,15 C40,5 60,15 70,35"
        android:strokeWidth="1"
        android:strokeColor="#40FFFFFF"
        android:strokeLineCap="round" />

    <!-- Stylized Infinity-F Symbol -->
    <!-- Represents continuity and flow -->
    <path
        android:pathData="M35,35 L73,35 C80,35 80,45 73,45 L50,45 L73,68 C80,75 70,85 63,78 L35,50 L35,85"
        android:strokeWidth="8"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
        
    <path
        android:pathData="M35,58 L55,58"
        android:strokeWidth="8"
        android:strokeColor="#FFFFFF"
        android:strokeLineCap="round" />

    <!-- Technical dots to make it more "Techy" -->
    <path
        android:pathData="M85,85 A3,3 0 1,1 84.99,85 Z"
        android:fillColor="#00A3FF" />
</vector>
